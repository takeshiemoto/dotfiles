{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "NotebookEdit",
      "mcp__plugin_context7_context7",
      "mcp__plugin_kbs-samba4_chrome-devtools"
    ],
    "deny": [
      "Bash(npx *)",
      "Bash(pup investigations trigger *)",
      "Bash(pup acp serve *)",
      "Bash(pup idp assist *)",
      "Bash(pup llm-obs *)"
    ],
    "ask": [
      "Bash(git push *)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "kbs-samba4@kubell-storage-plugins": true,
    "kbs-basic@kubell-storage-plugins": true,
    "codex@openai-codex": true,
    "takeshiemoto@takeshiemoto-marketplace": true
  },
  "extraKnownMarketplaces": {
    "kubell-storage-plugins": {
      "source": {
        "source": "github",
        "repo": "chatwork-st/kubell-storage-claude-plugin"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "takeshiemoto-marketplace": {
      "source": {
        "source": "github",
        "repo": "takeshiemoto/claude-code-my-marketplace"
      },
      "autoUpdate": true
    },
    "datadog-pup": {
      "source": {
        "source": "github",
        "repo": "datadog-labs/pup"
      },
      "autoUpdate": true
    }
  },
  "language": "japanese",
  "effortLevel": "max",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
